datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
  previewFeatures      = ["postgresqlExtensions"]
  output               = "../../.venv/Lib/site-packages/prisma"
}

model Campaign {
  id                String      @id @default(uuid())
  userId            String?     // Supabase Auth user ID
  title             String
  jobDescription    String
  distilledJd       String?
  jdEmbedding       Unsupported("vector(1536)")?
  hardFiltersConfig Json?
  enableInterviews  Boolean     @default(true)
  interviewConfig   String?
  evaluationStrictness String   @default("moderate")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  candidates        Candidate[]

  @@index([userId])
}

model Candidate {
  id              String      @id @default(uuid())
  campaignId      String
  name            String
  email           String?
  phone           String?
  status          String      @default("pending") // pending, rejected, interviewing, review, finalized
  fitScore        Float?
  decision        String?     // final decision by recruiter: approve, reject, hold
  rejectionReason String?
  skills          String[]
  education       String[]
  cvUrl           String?
  
  resumeId        String?
  resume          Resume?     @relation(fields: [resumeId], references: [id])
  
  campaign        Campaign    @relation(fields: [campaignId], references: [id])
  evaluation      Evaluation?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // COST_TRACKING: Remove after testing
  apiCost         Float       @default(0)

  @@index([campaignId])
  @@index([resumeId])
  @@index([campaignId, status])
  @@index([createdAt])
  @@index([updatedAt])
}

model Resume {
  id                String      @id @default(uuid())
  fileHash          String      @unique
  structuredProfile Json?
  rawCvText         String?
  embedding         Unsupported("vector(1536)")?
  
  candidates        Candidate[]
  
  createdAt         DateTime    @default(now())
}

model Evaluation {
  id                  String    @id @default(uuid())
  candidateId         String    @unique
  overallScore        Float
  technicalScore      Float
  communicationScore  Float
  culturalFitScore    Float
  recommendation      String
  summary             String
  strengths           String[]
  concerns            String[]
  chainOfThought      String?
  interviewTranscript Json?
  interviewQuestions  Json?
  
  candidate           Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  
  createdAt           DateTime  @default(now())
}

model CandidateAnalytics {
  id              String   @id @default(uuid())
  campaignId      String
  campaignTitle   String
  status          String
  fitScore        Float?
  overallScore    Float?
  exitStage       String?
  createdAt       DateTime @default(now())

  @@index([campaignId])
}

